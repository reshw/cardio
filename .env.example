# Supabase
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_PUBLISHABLE_KEY=your_publishable_key_here

# Kakao OAuth
VITE_KAKAO_REST_API_KEY=your_kakao_rest_api_key_here
VITE_KAKAO_JAVASCRIPT_KEY=your_kakao_javascript_key_here
VITE_KAKAO_CLIENT_SECRET=your_kakao_client_secret_here

# Cloudinary
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name_here
VITE_CLOUDINARY_API_KEY=your_api_key_here
VITE_CLOUDINARY_UPLOAD_PRESET=your_upload_preset_here

# Resend (이메일 발송)
# 주의: Netlify Functions에서 사용되므로 Netlify 환경변수로 설정 필요
# VITE_ 프리픽스 없이 RESEND_API_KEY로 설정
RESEND_API_KEY=your_resend_api_key_here
