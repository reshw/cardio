```tsx
// ❌ 나쁜 예: 서버 상태를 로컬 상태로 중복 관리
const [user, setUser] = useState(null);
useEffect(() => {
  fetchUser().then(setUser);
}, []);

// ✅ 좋은 예: Context로 전역 관리
const { user } = useAuth();

// ✅ 더 좋은 예: React Query (향후)
const { data: user, isLoading } = useQuery('user', fetchUser);
```

