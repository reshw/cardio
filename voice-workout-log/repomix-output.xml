    const todos = getAllTodos();
    const existingIndex = todos.findIndex((t) => t.id === todo.id);

    if (existingIndex >= 0) {
      todos[existingIndex] = todo;
    } else {
      todos.push(todo);
    }

    todos.sort((a, b) => b.createdAt - a.createdAt);
